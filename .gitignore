# --- Unity Folders ---
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# --- Assets & Plugins ---
# Ignore Asset Store tools and autogenerated JetBrains/Rider/Visual Studio files
/[Aa]ssets/AssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*
/[Aa]ssets/Plugins/Editor/JetBrains.meta
.vs/
.gradle/

# --- Project & Solution Files ---
# These are autogenerated by Unity; keeping them causes constant merge conflicts
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta

# --- Unity Generated Metadata ---
sysinfo.txt
crashlytics-build.properties

# --- Addressables & StreamingAssets ---
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# --- Build Artifacts ---
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
*.exe
*.zip
*.7z

# --- OS Specific ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db

# --- PlasticSCM & Version Control ---
/[Aa]ssets/Plugins/PlasticSCM*
.plastic/